# Copy to .env before using Docker Compose.
POSTGRES_DB=aimusic
POSTGRES_USER=aimusic
POSTGRES_PASSWORD=replace-with-a-strong-database-password
JWT_SECRET=replace-with-at-least-32-random-characters
BACKEND_PORT=8080

# fake | minimax | replicate
AI_PROVIDER=fake

# Only required by the selected real provider.
MINIMAX_API_KEY=
MINIMAX_MODEL=music-2.6-free
REPLICATE_API_TOKEN=
