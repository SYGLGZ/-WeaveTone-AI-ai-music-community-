# This file is documentation only. Export the variables in your shell or use the
# provided Windows launch scripts; the Ktor app intentionally does not auto-load .env.

PORT=8080
DB_URL=jdbc:h2:file:./data/aimusic_demo;MODE=PostgreSQL;DATABASE_TO_LOWER=TRUE
DB_USER=sa
DB_PASSWORD=
JWT_SECRET=replace-with-a-long-random-string

# fake | minimax | replicate
AI_PROVIDER=fake

# MiniMax
MINIMAX_API_KEY=
MINIMAX_MODEL=music-2.6-free
MINIMAX_OUTPUT_FORMAT=url
MINIMAX_INSTRUMENTAL=true
MINIMAX_REQUEST_TIMEOUT_MS=300000

# Replicate
REPLICATE_API_TOKEN=
REPLICATE_MODEL_OWNER=meta
REPLICATE_MODEL_NAME=musicgen
REPLICATE_MODEL_VERSION=
